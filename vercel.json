{
  "version": 2,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/portal/(.*)",
      "destination": "/portal/index.html"
    },
    {
      "source": "/portal",
      "destination": "/portal/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/portal",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/portal/(.*)",
      "destination": "/",
      "permanent": false
    }
  ]
}
